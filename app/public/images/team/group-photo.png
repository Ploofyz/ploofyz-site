<svg width="1200" height="600" xmlns="http://www.w3.org/2000/svg">
  <!-- Background gradient -->
  <defs>
    <linearGradient id="skyGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#87CEEB;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4A90A4;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="groundGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#8B7355;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#654321;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Sky -->
  <rect width="1200" height="400" fill="url(#skyGradient)"/>
  
  <!-- Ground -->
  <rect y="400" width="1200" height="200" fill="url(#groundGradient)"/>
  
  <!-- Sun -->
  <circle cx="1000" cy="100" r="60" fill="#FFD700" opacity="0.8"/>
  
  <!-- Minecraft-style blocks in background -->
  <rect x="100" y="350" width="50" height="50" fill="#8B4513" stroke="#654321" stroke-width="2"/>
  <rect x="150" y="350" width="50" height="50" fill="#A0522D" stroke="#654321" stroke-width="2"/>
  <rect x="200" y="350" width="50" height="50" fill="#8B4513" stroke="#654321" stroke-width="2"/>
  
  <rect x="900" y="320" width="50" height="80" fill="#228B22" stroke="#1a6b1a" stroke-width="2"/>
  <rect x="900" y="300" width="50" height="20" fill="#32CD32" stroke="#1a6b1a" stroke-width="2"/>
  
  <!-- Team silhouettes (simplified Minecraft-style characters) -->
  <!-- Character 1 -->
  <rect x="200" y="280" width="60" height="80" fill="#4A90E2" stroke="#2E5C8A" stroke-width="2"/>
  <rect x="215" y="250" width="30" height="30" fill="#FFB6C1" stroke="#FF69B4" stroke-width="2"/>
  
  <!-- Character 2 -->
  <rect x="300" y="270" width="60" height="90" fill="#9B59B6" stroke="#6C3483" stroke-width="2"/>
  <rect x="315" y="240" width="30" height="30" fill="#F4D03F" stroke="#D4AF37" stroke-width="2"/>
  
  <!-- Character 3 -->
  <rect x="400" y="275" width="60" height="85" fill="#E74C3C" stroke="#C0392B" stroke-width="2"/>
  <rect x="415" y="245" width="30" height="30" fill="#85C1E2" stroke="#5DADE2" stroke-width="2"/>
  
  <!-- Character 4 -->
  <rect x="500" y="280" width="60" height="80" fill="#1ABC9C" stroke="#16A085" stroke-width="2"/>
  <rect x="515" y="250" width="30" height="30" fill="#F39C12" stroke="#D68910" stroke-width="2"/>
  
  <!-- Character 5 -->
  <rect x="600" y="275" width="60" height="85" fill="#F39C12" stroke="#D68910" stroke-width="2"/>
  <rect x="615" y="245" width="30" height="30" fill="#E8DAEF" stroke="#D7BDE2" stroke-width="2"/>
  
  <!-- Character 6 -->
  <rect x="700" y="270" width="60" height="90" fill="#3498DB" stroke="#2874A6" stroke-width="2"/>
  <rect x="715" y="240" width="30" height="30" fill="#ABEBC6" stroke="#82E0AA" stroke-width="2"/>
  
  <!-- Character 7 -->
  <rect x="800" y="280" width="60" height="80" fill="#E67E22" stroke="#CA6F1E" stroke-width="2"/>
  <rect x="815" y="250" width="30" height="30" fill="#FAD7A0" stroke="#F8C471" stroke-width="2"/>
  
  <!-- Character 8 -->
  <rect x="900" y="275" width="60" height="85" fill="#16A085" stroke="#138D75" stroke-width="2"/>
  <rect x="915" y="245" width="30" height="30" fill="#F5B7B1" stroke="#F1948A" stroke-width="2"/>
  
  <!-- Title text -->
  <text x="600" y="550" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="#FFFFFF" text-anchor="middle" stroke="#000000" stroke-width="2">
    Meet the Ploofyz Team
  </text>
</svg>

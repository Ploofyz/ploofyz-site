<svg width="400" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- Background circle with role color -->
  <circle cx="200" cy="200" r="180" fill="#ef4444" opacity="0.9"/>
  
  <!-- Minecraft-style character head -->
  <rect x="100" y="100" width="200" height="200" fill="#FFE4E1" stroke="#D2B48C" stroke-width="4"/>
  
  <!-- Eyes -->
  <rect x="130" y="160" width="40" height="40" fill="#E74C3C" stroke="#C0392B" stroke-width="2"/>
  <rect x="230" y="160" width="40" height="40" fill="#E74C3C" stroke="#C0392B" stroke-width="2"/>
  
  <!-- Mouth -->
  <rect x="160" y="240" width="80" height="20" fill="#8B4513" stroke="#654321" stroke-width="2"/>
  
  <!-- Hair/accessory -->
  <rect x="100" y="80" width="200" height="30" fill="#ef4444" stroke="#C0392B" stroke-width="2"/>
  
  <!-- Initial badge -->
  <circle cx="320" cy="320" r="50" fill="#FFFFFF" stroke="#ef4444" stroke-width="4"/>
  <text x="320" y="340" font-family="Arial, sans-serif" font-size="40" font-weight="bold" fill="#ef4444" text-anchor="middle">
    M
  </text>
</svg>
